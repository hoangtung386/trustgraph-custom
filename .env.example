# =============================================================================
# TrustGraph Environment Variables
# Copy this file to .env and fill in your credentials
# =============================================================================

# --- OpenRouter ---
# Get your API key at: https://openrouter.ai/keys
# Provides access to 200+ models (OpenAI, Anthropic, Google, Mistral, Meta, etc.)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# --- Qdrant Cloud ---
# Create a free cluster at: https://cloud.qdrant.io
# Cluster URL (e.g., https://xxxxx-xxxxx.aws.cloud.qdrant.io:6333)
QDRANT_HOST=https://your-cluster-url.cloud.qdrant.io
QDRANT_PORT=6333
QDRANT_API_KEY=your-qdrant-api-key

# --- Cassandra Cloud (DataStax Astra DB) ---
# Create a free DB at: https://astra.datastax.com
# Get the secure connect bundle and credentials
CASSANDRA_HOST=your-astra-host.datastax.com
CASSANDRA_PORT=29042
CASSANDRA_USERNAME=token
CASSANDRA_PASSWORD=AstraCS:your-astra-token
CASSANDRA_SECURE_CONNECT_BUNDLE_PATH=/path/to/secure-connect-bundle.zip

# --- Ingest Automation API Endpoints (NEW) ---
# POST /api/v1/ingest  — Upload file (multipart) + auto-trigger pipeline
#  Fields: file (required), flow, collection, title
#  Returns: { document_id, pdf_url, status_url, graph_url }
#
# GET /api/v1/ingest/{document_id}/status  — Check processing status
#  Returns: { status, stages, page_count, chunk_count }
#
# GET /api/v1/ingest/{document_id}/graph   — Get extracted knowledge graph
#  Returns: { triples, entities, triple_count }
#
# Quick test:
#   curl -X POST http://localhost:8088/api/v1/ingest \
#     -H "Authorization: Bearer <token>" \
#     -F "file=@document.pdf" \
#     -F "flow=my-flow"
